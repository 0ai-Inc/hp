---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description } = Astro.props;
---

<div class="group p-6 rounded-xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.05] transition-all duration-300">
  <h3 class="text-lg font-semibold text-white group-hover:text-accent-light transition-colors">
    {title}
  </h3>
  <p class="mt-3 text-sm text-white/50 leading-relaxed">
    {description}
  </p>
</div>
