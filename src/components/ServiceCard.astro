---
interface Props {
  title: string;
  description: string;
  icon?: string;
  href?: string;
}

const { title, description, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  class="group block p-6 rounded-xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.05] transition-all duration-300"
  {...href ? { href, target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  <h3 class="text-lg font-semibold text-white group-hover:text-accent-light transition-colors">
    {title}
    {href && <span class="inline-block ml-1 text-xs text-white/30 group-hover:text-accent-light/70 transition-colors">↗</span>}
  </h3>
  <p class="mt-3 text-sm text-white/50 leading-relaxed">
    {description}
  </p>
</Tag>
