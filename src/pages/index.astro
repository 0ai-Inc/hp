---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations('ja');

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://0ai-inc.com/#organization",
  "name": "株式会社0ai",
  "alternateName": "0ai Inc.",
  "url": "https://0ai-inc.com",
  "logo": "https://0ai-inc.com/favicon.svg",
  "description": "人間活動のAI化とAIの人間化の追求。人間とAIの境界を0にする企業。",
  "foundingDate": "2026-01",
  "email": "info@0ai-inc.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "日本橋室町1丁目11番12号 日本橋水野ビル7階",
    "addressLocality": "中央区",
    "addressRegion": "東京都",
    "postalCode": "103-0022",
    "addressCountry": "JP"
  },
  "sameAs": []
};
---

<BaseLayout title={t('site.title')} description={t('site.description')} lang="ja" jsonLd={organizationSchema}>
  <Hero />

  <section class="py-20 sm:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold">{t('services.title')}</h2>
        <p class="mt-4 text-white/50 max-w-2xl mx-auto">{t('services.subtitle')}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <ServiceCard title={t('services.nexcast.title')} description={t('services.nexcast.desc')} />
        <ServiceCard title={t('services.envoy.title')} description={t('services.envoy.desc')} />
        <ServiceCard title={t('services.flecto.title')} description={t('services.flecto.desc')} href="https://flecto.zer0ai.dev" />
        <ServiceCard title={t('services.animex.title')} description={t('services.animex.desc')} />
        <ServiceCard title={t('services.custom.title')} description={t('services.custom.desc')} />
        <ServiceCard title={t('services.consult.title')} description={t('services.consult.desc')} href="/contact" />
      </div>
    </div>
  </section>
</BaseLayout>
