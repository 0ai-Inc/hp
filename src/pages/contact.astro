---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations('ja');
---

<BaseLayout title={`${t('contact.title')} | ${t('site.title.brand')}`} description={t('contact.subtitle')} lang="ja">
  <section class="py-20 sm:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h1 class="text-3xl sm:text-4xl font-bold text-center mb-4">{t('contact.title')}</h1>
      <p class="text-center text-white/50 mb-16 max-w-2xl mx-auto">{t('contact.subtitle')}</p>

      <div class="max-w-2xl mx-auto">
        <div class="mb-8 p-5 rounded-xl border border-accent/20 bg-accent/5 text-center">
          <h2 class="text-sm font-semibold mb-1">{t('contact.free')}</h2>
          <p class="text-white/50 text-xs">{t('contact.free.desc')}</p>
        </div>

        <form id="contact-form" class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-white/70 mb-2">{t('contact.form.name')} <span class="text-red-400">*</span></label>
              <input type="text" id="name" name="name" required
                class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-white/30 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-white/70 mb-2">{t('contact.form.email')} <span class="text-red-400">*</span></label>
              <input type="email" id="email" name="email" required
                class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-white/30 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="company" class="block text-sm font-medium text-white/70 mb-2">{t('contact.form.company')}</label>
              <input type="text" id="company" name="company"
                class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-white/30 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors"
              />
            </div>
            <div>
              <label for="category" class="block text-sm font-medium text-white/70 mb-2">{t('contact.form.category')} <span class="text-red-400">*</span></label>
              <select id="category" name="category" required
                class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors appearance-none"
                style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 12 12%22%3E%3Cpath fill=%22%23ffffff%22 d=%22M6 8L1 3h10z%22/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 12px center;"
              >
                <option value="" disabled selected class="bg-[#061124]">--</option>
                <option value="無料相談" class="bg-[#061124]">{t('contact.form.category.consult')}</option>
                <option value="受託開発" class="bg-[#061124]">{t('contact.form.category.custom')}</option>
                <option value="プロダクト" class="bg-[#061124]">{t('contact.form.category.product')}</option>
                <option value="協業" class="bg-[#061124]">{t('contact.form.category.partnership')}</option>
                <option value="その他" class="bg-[#061124]">{t('contact.form.category.other')}</option>
              </select>
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-white/70 mb-2">{t('contact.form.message')} <span class="text-red-400">*</span></label>
            <textarea id="message" name="message" rows="6" required
              class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-white/30 focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-colors resize-y"
            ></textarea>
          </div>

          <button type="submit" id="submit-btn"
            class="w-full px-8 py-3 bg-white text-primary font-semibold rounded-lg hover:bg-white/90 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span id="btn-text">{t('contact.form.submit')}</span>
            <span id="btn-loading" class="hidden">{t('contact.form.sending')}</span>
          </button>
        </form>

        <div id="success-message" class="hidden mt-8 p-6 rounded-xl border border-green-500/20 bg-green-500/5 text-green-300">
          {t('contact.form.thanks')}
        </div>

        <div id="error-message" class="hidden mt-4 p-4 rounded-lg border border-red-500/20 bg-red-500/5 text-red-300 text-sm">
          {t('contact.form.error')}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const GAS_URL = 'https://script.google.com/macros/s/AKfycbxeZNSSbNgWveOafcpS6W1-KncH_ApTV1ydT0jw4q72aZOXAugAMqTtV5gozsbTOfSLNQ/exec';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text')!;
  const btnLoading = document.getElementById('btn-loading')!;
  const successMsg = document.getElementById('success-message')!;
  const errorMsg = document.getElementById('error-message')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');
    submitBtn.disabled = true;
    btnText.classList.add('hidden');
    btnLoading.classList.remove('hidden');

    const formData = new FormData(form);
    const data = {
      name: formData.get('name'),
      email: formData.get('email'),
      company: formData.get('company'),
      category: formData.get('category'),
      message: formData.get('message'),
      lang: 'ja',
    };

    try {
      await fetch(GAS_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'text/plain' },
        body: JSON.stringify(data),
      });
      form.classList.add('hidden');
      successMsg.classList.remove('hidden');
      if (typeof gtag === 'function') {
        gtag('event', 'form_submit', {
          event_category: 'contact',
          event_label: String(data.category),
        });
      }
    } catch {
      errorMsg.classList.remove('hidden');
      submitBtn.disabled = false;
      btnText.classList.remove('hidden');
      btnLoading.classList.add('hidden');
    }
  });
</script>
