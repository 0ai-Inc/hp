---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');
---

<BaseLayout title={`${t('contact.title')} | ${t('site.title')}`} description={t('contact.subtitle')} lang="en">
  <section class="py-20 sm:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h1 class="text-3xl sm:text-4xl font-bold text-center mb-4">{t('contact.title')}</h1>
      <p class="text-center text-white/50 mb-16 max-w-2xl mx-auto">{t('contact.subtitle')}</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-8 rounded-xl border border-white/5 bg-white/[0.02]">
          <h2 class="text-lg font-semibold mb-4">{t('contact.email.label')}</h2>
          <a href="mailto:info@0ai-inc.com" class="text-accent-light hover:underline text-lg">
            info@0ai-inc.com
          </a>
        </div>

        <div class="p-8 rounded-xl border border-white/5 bg-white/[0.02]">
          <h2 class="text-lg font-semibold mb-4">{t('contact.address.label')}</h2>
          <p class="text-white/60 text-sm whitespace-pre-line">{t('about.company.address.value')}</p>
        </div>
      </div>

      <div class="mt-12 p-8 rounded-xl border border-accent/20 bg-accent/5 text-center">
        <h2 class="text-xl font-semibold mb-2">{t('contact.free')}</h2>
        <p class="text-white/60 text-sm">{t('contact.free.desc')}</p>
        <a
          href="mailto:info@0ai-inc.com?subject=Free Consultation Request"
          class="inline-block mt-6 px-8 py-3 bg-white text-primary font-semibold rounded-lg hover:bg-white/90 transition-colors"
        >
          {t('hero.contact')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
