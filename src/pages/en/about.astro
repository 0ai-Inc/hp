---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');
---

<BaseLayout title={`${t('about.title')} | ${t('site.title')}`} description={t('about.mission.desc')} lang="en">
  <section class="py-20 sm:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h1 class="text-3xl sm:text-4xl font-bold text-center mb-16">{t('about.title')}</h1>

      <div class="mb-20">
        <div class="text-center mb-12 py-8 border-y border-white/10">
          <p class="text-sm tracking-widest text-white/40 uppercase mb-3">{t('about.vision.title')}</p>
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">{t('about.vision.statement')}</h2>
          <p class="mt-4 text-white/50 max-w-xl mx-auto">{t('about.vision.desc')}</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
          <div class="p-6 rounded-xl border border-white/5 bg-white/[0.02]">
            <p class="text-sm tracking-widest text-white/40 uppercase mb-2">{t('about.mission.title')}</p>
            <p class="text-white/70 leading-relaxed">{t('about.mission.desc')}</p>
          </div>
          <div class="p-6 rounded-xl border border-white/5 bg-white/[0.02]">
            <p class="text-sm tracking-widest text-white/40 uppercase mb-2">{t('about.value.title')}</p>
            <p class="text-white/70 leading-relaxed">{t('about.value.desc')}</p>
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-xl font-semibold mb-6">{t('about.company.title')}</h2>
        <div class="border border-white/5 rounded-xl overflow-hidden">
          <dl class="divide-y divide-white/5">
            <div class="flex flex-col sm:flex-row px-6 py-4">
              <dt class="sm:w-40 text-sm text-white/40 mb-1 sm:mb-0">Company Name</dt>
              <dd class="text-sm">{t('about.company.name')}</dd>
            </div>
            <div class="flex flex-col sm:flex-row px-6 py-4">
              <dt class="sm:w-40 text-sm text-white/40 mb-1 sm:mb-0">{t('about.company.representative')}</dt>
              <dd class="text-sm">{t('about.company.representative.value')}</dd>
            </div>
            <div class="flex flex-col sm:flex-row px-6 py-4">
              <dt class="sm:w-40 text-sm text-white/40 mb-1 sm:mb-0">{t('about.company.established')}</dt>
              <dd class="text-sm">{t('about.company.established.value')}</dd>
            </div>
            <div class="flex flex-col sm:flex-row px-6 py-4">
              <dt class="sm:w-40 text-sm text-white/40 mb-1 sm:mb-0">{t('about.company.capital')}</dt>
              <dd class="text-sm">{t('about.company.capital.value')}</dd>
            </div>
            <div class="flex flex-col sm:flex-row px-6 py-4">
              <dt class="sm:w-40 text-sm text-white/40 mb-1 sm:mb-0">{t('about.company.corporate_number')}</dt>
              <dd class="text-sm">{t('about.company.corporate_number.value')}</dd>
            </div>
            <div class="flex flex-col sm:flex-row px-6 py-4">
              <dt class="sm:w-40 text-sm text-white/40 mb-1 sm:mb-0">{t('about.company.address')}</dt>
              <dd class="text-sm whitespace-pre-line">{t('about.company.address.value')}</dd>
            </div>
            <div class="flex flex-col sm:flex-row px-6 py-4">
              <dt class="sm:w-40 text-sm text-white/40 mb-1 sm:mb-0">{t('about.company.email')}</dt>
              <dd class="text-sm">
                <a href="mailto:info@0ai-inc.com" class="text-accent-light hover:underline">info@0ai-inc.com</a>
              </dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
